.DS_Store
Thumbs.db
.vscode/
.idea/

# Stray local test artifacts
test*.pdf

# Data/model artifacts are versioned via DVC, not Git (see .dvc pointer files)
/data/raw/*
!/data/raw/*.dvc
/data/processed/*
!/data/processed/*.dvc
/data/features/*
!/data/features/*.dvc
/warehouse/*
!/warehouse/*.dvc
/models/*
!/models/*.dvc
